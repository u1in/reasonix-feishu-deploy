# ============================================================================
# Reasonix API 密钥配置文件
# 将此文件重命名为 .env 并放到 ~/.config/vercel-ai-tools/.env
# 警告: 此文件包含敏感密钥，切勿提交到版本控制！
# ============================================================================

# ── 必填 ──

# DeepSeek API Key
# 注册: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 飞书 Bot App Secret
# 在飞书开放平台 → 你的应用 → 凭证与基础信息 中获取
FEISHU_BOT_APP_SECRET=your-feishu-app-secret-here

# ── 可选（按需启用） ──

# QQ Bot App Secret（QQ 频道机器人）
# QQ_BOT_APP_SECRET=your-qq-bot-secret

# 微信 Bot Token（个人微信接入，需 iLink 平台）
# WEIXIN_BOT_TOKEN=your-weixin-token

# 网络代理（如果你的服务器需要代理才能访问 API）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
